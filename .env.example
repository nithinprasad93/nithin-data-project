# Copy this to .env and fill in real values. Never commit .env to git.

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Snowflake ─────────────────────────────────────────────────
# Account identifier format: <org_name>-<account_name>  (e.g. abc123-myaccount)
SNOWFLAKE_ACCOUNT=your-account-identifier

# Loader (Python seeder / ingestion)
SNOWFLAKE_USER=SVC_LOADER
SNOWFLAKE_PASSWORD=your_loader_password
SNOWFLAKE_ROLE=NDIS_LOADER
SNOWFLAKE_DATABASE=NDIS_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=NDIS_WH

# Transformer (dbt — override in profiles.yml via env vars)
# SNOWFLAKE_USER=SVC_TRANSFORMER
# SNOWFLAKE_PASSWORD=your_transformer_password

# Reporter (Evidence.dev)
# SNOWFLAKE_USER=SVC_REPORTER
# SNOWFLAKE_PASSWORD=your_reporter_password

# ── Notifications ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
RESEND_API_KEY=re_...
NOTIFY_EMAIL=your@email.com

# ── Vercel ────────────────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID_EVIDENCE=...
